{
  "name": "region-control",
  "description": "华润新能源控股有限公司-新能源区域集控系统",
  "homepage": "/",
  "private": true,
  "version": "1.0.2",
  "author": "xxx <xxxx@xxx.com>",
  "main": "./dist/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --report-unused-disable-directives --max-warnings 0 --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "fix-memory-limit": "cross-env LIMIT=4096 increase-memory-limit",
    "dev": "dotenv -e .env.tauri.dev vite",
    "start": "dotenv -e .env.dev vite",
    "build:tauri": "tsc && dotenv -e .env.tauri.prod vite build",
    "build": "tsc && dotenv -e .env.prod vite build",
    "start:ele": "dotenv -e .env.ele.dev electron-vite dev",
    "build:ele": "tsc && dotenv -e .env.ele.prod electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "pack:win": "npm run build:ele && electron-builder --win --config",
    "pack:mac": "npm run build:ele && electron-builder --mac --config",
    "pack:linux": "npm run build:ele && electron-builder --linux --config",
    "setpkgtype": "babel-node ./plugins/set-pkg-type/index.mjs",
    "preview": "vite preview",
    "preview:ele": "electron-vite preview",
    "preinstall": "npx only-allow pnpm",
    "test": "tauri dev"
  },
  "resolutions": {
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@electron-toolkit/preload": "^3.0.0",
