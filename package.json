    "@electron-toolkit/tsconfig": "^1.0.1",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@tauri-apps/cli": "^1.6.2",
    "@types/color": "^3.0.6",
    "@types/jquery": "^3.5.29",
    "@types/node": "^20.11.5",
    "@types/qs": "^6.9.11",
